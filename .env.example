MYSQL_ROOT_PASSWORD=root_password
MYSQL_DATABASE=doc_parse_qa
MYSQL_USER=docqa
MYSQL_PASSWORD=docqa_password
MYSQL_PORT=3406
SERVER_PORT=8082
WEB_PORT=8083
RUSTFS_PORT=9000
# 局域网 IP 访问已自动放行（192.168.x.x / 10.x.x.x）；也可显式追加，如 http://192.168.1.100:8083
CORS_ALLOWED_ORIGINS=http://localhost:8083,http://127.0.0.1:8083
# RustFS / S3 兼容对象存储配置（请自定义凭证，勿提交到 Git）
S3_ENDPOINT=rustfs:9000
S3_ACCESS_KEY=rustfsadmin
S3_SECRET_KEY=rustfsadmin
S3_BUCKET=documents
S3_REGION=us-east-1
S3_USE_SSL=false
# 阿里百炼 DashScope API Key，仅通过环境变量注入，勿提交到 Git
DASHSCOPE_API_KEY=
UPLOAD_DIR=./uploads
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
DASHSCOPE_MODEL=qwen-plus
DASHSCOPE_TIMEOUT_SECONDS=300
MINERU_BASE_URL=http://10.3.17.83:7861
MINERU_TIMEOUT_SECONDS=300
